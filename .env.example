# Telegram
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# VPN: пароль по умолчанию (если у профиля не указан свой pass)
VPN_PASSWORD=your_vpn_password

# Профили VPN — JSON (в одну строку). user по умолчанию "sstp", pass — свой или из VPN_PASSWORD
VPN_PROFILES=[{"profile":"m1","user":"sstp","pass":"password1","ipStart":"192.168.1.1","ipEnd":"192.168.1.10"}]

# Майнер (порт API по умолчанию 4028)
MINER_PORT=4028
